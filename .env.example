# =============================================================================
# .env.example — copy to .env and fill in values
# Never commit .env to git.
# =============================================================================

# --- App ---
APP_NAME=MyApp
NODE_ENV=development

# --- API (NestJS) ---
PORT=3001
CORS_ORIGINS=http://localhost:3000
# URL of the frontend app (used to build email links: password reset, invitations)
APP_URL=http://localhost:3000

# --- Auth (Better Auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
# Root URL of the API (Better Auth uses this for OAuth callbacks)
BETTER_AUTH_URL=http://localhost:3001

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appdb
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=20
DB_CONNECT_TIMEOUT=10

# --- Redis ---
REDIS_PASSWORD=redis
REDIS_PORT=6379
REDIS_URL=redis://:redis@localhost:6379
QUEUE_PREFIX=template

# --- Observability ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1
SENTRY_TRACES_SAMPLE_RATE=0

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost
MINIO_BUCKET=uploads

# --- Email (MailHog in dev) ---
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MyApp <noreply@localhost>

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Root URL of the API — used by Better Auth client (no /api suffix)
NEXT_PUBLIC_AUTH_URL=http://localhost:3001
