{
  "name": "turbo-nest-next",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "api:dev": "pnpm --filter=@repo/api dev",
    "web:dev": "pnpm --filter=@repo/web dev",
    "api:start:prod": "pnpm --filter=@repo/api start:prod",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\" --ignore-path .gitignore",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "api:generate": "pnpm --filter=@repo/api openapi:generate && pnpm --filter=@repo/web api:generate",
    "api:check": "pnpm api:generate && git diff --exit-code -- apps/api/openapi.json apps/web/lib/api-schema.ts",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "infra:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "db:generate": "dotenv -e .env -- turbo run db:generate --filter=@repo/db",
    "db:migrate": "dotenv -e .env -- turbo run db:migrate --filter=@repo/db",
    "db:studio": "dotenv -e .env -- turbo run db:studio --filter=@repo/db",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.4",
    "typescript": "6.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
