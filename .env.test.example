# Test profile. Copy to .env.test when you want isolated local test services.

APP_NAME=MyApp
NODE_ENV=test

PORT=3001
CORS_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000

BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3001

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb_test
POSTGRES_PORT=55432
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/appdb_test

REDIS_PASSWORD=redis
REDIS_PORT=56379
REDIS_URL=redis://:redis@localhost:56379

MAILHOG_SMTP_PORT=11025
MAILHOG_UI_PORT=18025
SMTP_HOST=localhost
SMTP_PORT=11025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MyApp <noreply@localhost>

NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_AUTH_URL=http://localhost:3001
