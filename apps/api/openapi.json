          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "emailVerified": {
            "type": "boolean"
          },
          "image": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "emailVerified",
          "createdAt",
          "updatedAt"
        ]
      },
      "EnqueuePingJobResponseDto": {
        "type": "object",
        "properties": {
          "queued": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        },
        "required": ["queued", "message"]
      },
      "EnqueuePingJobDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "hello from the API"
          }
        },
        "required": ["message"]
      }
    }
