# Domains
APP_DOMAIN=example.com
API_DOMAIN=api.example.com

# Images. Override these when pulling from a registry instead of building on the server.
API_IMAGE=turbo-nest-next-api:single-server
WEB_IMAGE=turbo-nest-next-web:single-server
WORKER_IMAGE=turbo-nest-next-worker:single-server
NODE_VERSION=22

# App URLs
APP_NAME=MyApp
APP_URL=https://example.com
CORS_ORIGINS=https://example.com
BETTER_AUTH_URL=https://api.example.com
NEXT_PUBLIC_API_URL=https://api.example.com/api
NEXT_PUBLIC_AUTH_URL=https://api.example.com

# Secrets
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me

# Persistence
POSTGRES_USER=postgres
POSTGRES_DB=appdb
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/appdb
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=20
DB_CONNECT_TIMEOUT=10
REDIS_URL=redis://:change-me@redis:6379
QUEUE_PREFIX=template

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_SMOKE_TEST_ENABLED=false

# SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MyApp <noreply@example.com>
