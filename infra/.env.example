APP_DOMAIN=example.com
API_DOMAIN=api.example.com
CLOUDFLARE_ZONE_ID=change-me

# GitHub repo to clone on the server. Use owner/repo.
GITHUB_REPO=salemaljebaly/turbo-nest-next
GITHUB_REF=main
GITHUB_TOKEN=ghp_change_me

# App secrets
APP_NAME=MyApp
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me

# Optional observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_SMOKE_TEST_ENABLED=false

# Optional SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MyApp <noreply@example.com>

# Optional backups. The Pulumi bootstrap enables the backup timer only when these are set.
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=auto
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=single-server
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_RETENTION_DAYS=7
MINIO_BUCKET=uploads
